# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=tu_password
DB_DATABASE=appsena
# El esquema lo gestionan las migraciones (synchronize está desactivado).
# En local corré `npm run migration:run` una vez. Poné DB_MIGRATIONS_RUN=true
# para que las migraciones se apliquen automáticamente al arrancar la app.
DB_MIGRATIONS_RUN=false

# JWT (JWT_SECRET debe tener 32+ caracteres — la app falla al arrancar si es más corto o falta)
JWT_SECRET=cambia_esto_por_un_secreto_aleatorio_de_al_menos_32_caracteres
JWT_EXPIRATION=1d

# AWS S3 (Capa gratuita)
# Crear cuenta en AWS y obtener credenciales en: https://console.aws.amazon.com/iam/
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_S3_BUCKET_NAME=appsena-evidencias

# Node Environment
NODE_ENV=development
