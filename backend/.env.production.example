# =========================================
# Environment Variables Template - Backend
# Copy this file and fill with your values
# =========================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Database Configuration (RDS PostgreSQL)
DB_HOST=your-rds-instance.xxxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_USERNAME=appsena_admin
DB_PASSWORD=YOUR_SECURE_PASSWORD_HERE
DB_DATABASE=appsena
# Migraciones: synchronize está desactivado. Aplicá el esquema con
# `npm run migration:run` en el pipeline de despliegue, o poné
# DB_MIGRATIONS_RUN=true para correrlas al arrancar (solo si hay UNA instancia,
# para evitar carreras entre réplicas).
DB_MIGRATIONS_RUN=false

# JWT Configuration
JWT_SECRET=GENERATE_RANDOM_STRING_MINIMUM_32_CHARACTERS
JWT_EXPIRATION=7d

# CORS Configuration
FRONTEND_URL=https://your-frontend-url.amazonaws.com

# AWS S3 (if using for uploads)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=YOUR_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET
# AWS_S3_BUCKET=appsena-uploads
